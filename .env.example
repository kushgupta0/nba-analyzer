# Copy this file to .env and fill in your key when you have it.
# The analyzer works without a key (using nba_api + HoopsHype scrape),
# but a paid API unlocks real VORP, BPM, and Win Shares from a reliable source.

# Paste your sports data API key here (BallDontLie, SportsDataIO, Sportradar, etc.)
SPORTS_API_KEY=

# Optional: override the default season year (default: 2024 = 2023-24 season)
# NBA_SEASON=2024
